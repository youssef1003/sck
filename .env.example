# ============================================================
# REQUIRED VERCEL ENVIRONMENT VARIABLES
# ============================================================
# These MUST be set in Vercel Dashboard > Settings > Environment Variables
# for the production deployment to work correctly.

# Supabase Configuration (REQUIRED)
SUPABASE_URL=https://kvngmywqilwhyavyjpc.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# JWT Configuration (REQUIRED)
# Must be at least 32 characters for security
JWT_SECRET=sck-consulting-super-secret-jwt-key-production-2024-min-32-chars

# AI APIs (OPTIONAL - AI Assistant will show fallback if not set)
# At least one of these is recommended for AI chat functionality
OPENAI_API_KEY=sk-your-openai-api-key-here
HF_API_KEY=hf_your_huggingface_api_key_here
GROK_API_KEY=xai-your-grok-api-key-here
GROK_API_URL=https://api.x.ai/v1/chat/completions

# Environment
NODE_ENV=production

# ============================================================
# IMPORTANT SETUP STEPS
# ============================================================
# 1. Set all REQUIRED variables in Vercel Dashboard
# 2. Run CREATE_LOGIN_FUNCTION.sql in Supabase SQL Editor
# 3. Run DATABASE_FIX_SIMPLE.sql in Supabase SQL Editor
# 4. Verify admin user exists: admin@sck.com / Admin@123456
# 5. Deploy to Vercel
# ============================================================